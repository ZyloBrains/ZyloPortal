@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="isDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="0" Style="background:#F5F5F5" Dense="true" Class="py-1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Dark" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudImage Src="https://raw.githubusercontent.com/ZyloBrains/Assets/refs/heads/main/logo.png" Alt="ZyloBrains" Height="40" />
        <MudSpacer />        
        <Login />
        <MudToggleIconButton @bind-Toggled="@isDarkMode"
                             Icon="@Icons.Material.Sharp.DarkMode"
                             ToggledIcon="@Icons.Material.Sharp.LightMode" />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="px-3 mt-3 pb-5">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    bool _drawerOpen = false;
    bool isDarkMode = false;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}