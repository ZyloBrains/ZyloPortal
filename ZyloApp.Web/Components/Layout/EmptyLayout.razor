@inherits LayoutComponentBase

@rendermode @(new InteractiveServerRenderMode(prerender: false))

<MudThemeProvider IsDarkMode="isDarkMode" />
<MudPopoverProvider />

<MudLayout>
    <MudMainContent>
        <MudAppBar Elevation="0" Style="background:#F5F5F5">
            <MudImage Src="https://raw.githubusercontent.com/ZyloBrains/Assets/refs/heads/main/logo.png" Alt="ZyloBrains" Height="50" />
            <MudSpacer />
            <MudToggleIconButton @bind-Toggled="@isDarkMode"
                                 Icon="@Icons.Material.Sharp.DarkMode"
                                 ToggledIcon="@Icons.Material.Sharp.LightMode" />
        </MudAppBar>
        @Body
        <MudToolBar Gutters="false" Class="mt-16 px-1 border-t-2 border-solid mud-border-warning" Dense>
            <MudText Typo="Typo.subtitle2" Style="font-size:1rem">@DateTime.Now.Year &copy; ZyloBrains</MudText>
            <MudSpacer />
            <MudText Typo="Typo.subtitle2" Style="font-size:1rem">With Love ❤️</MudText>
        </MudToolBar>
    </MudMainContent>
</MudLayout>

@code {
    bool isDarkMode = false;
}