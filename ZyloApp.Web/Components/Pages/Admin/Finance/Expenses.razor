@page "/expenses"

@using System.Globalization
@attribute [Authorize(Roles = Role.SuperAdmin)]
@inject ApplicationDbContext db
@inject ISnackbar SnackBar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>Expenses</PageTitle>

<MudDataGrid T="Expense"
             MultiSelection="true"
             Items="@expenses"
             SortMode="SortMode.Multiple"
             Hover="true"
             QuickFilter="@_quickFilter"
             Loading="loadingData"
             ReadOnly="true"
             Dense="true">
    <ToolBarContent>
        <MudFab Href="/expenses/add"
                StartIcon="@Icons.Material.Filled.Add"
                title="Add expense"
                Size="Size.Small"
                Color="Color.Tertiary" />
        <MudSpacer />
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search"
                      Adornment="Adornment.Start"
                      Immediate="true"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Class="mt-0"></MudTextField>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Title" Title="Particulars" />
        <PropertyColumn Property="x => x.Description" Title="Details" />
        <PropertyColumn Property="x => x.Date" Title="Date" Format="d" />
        <PropertyColumn Property="x => x.ExpenseType" Title="Expense Type" Groupable="true" />
        <PropertyColumn Property="x => x.Frequency" Title="Frequency" Groupable="true" />
        <TemplateColumn Title="Amount" AggregateDefinition="AmountAggregation">
            <CellTemplate>
                @context.Item.Amount.AsCurrency()
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.PaidBy" Title="Paid By" Groupable="true" />
        <TemplateColumn Title="Bill">
            <CellTemplate>
                @if (!string.IsNullOrEmpty(context.Item.BillImagePath))
                {
                    <MudImage Src="@context.Item.BillImagePath" Width="50" Height="50" ObjectFit="ObjectFit.Cover" Class="rounded-lg cursor-pointer" @onclick="() => OpenBillImage(context.Item)" />
                }
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.LastUpdatedBy" Title="Updated By" Groupable="true" />
        <TemplateColumn CellClass="d-flex justify-end">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Outlined.Edit" Href="@($"/expenses/edit/{context.Item.Id}")" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="Expense" PageSizeOptions="[50, 100, 200, 500]" />
    </PagerContent>
</MudDataGrid>

<style>
    .cursor-pointer {
        cursor: pointer;
    }
</style>

@code {

    private List<Expense> expenses = [];
    private string _searchString = string.Empty;
    private bool loadingData = false;

    AggregateDefinition<Expense> AmountAggregation = new()
    {
        Type = AggregateType.Custom,
        CustomAggregate = x =>
        {
            var totalExpense = x.Sum(y => y.Amount);
            return $"{totalExpense.AsCurrency()}";
        }
    };

    private Func<Expense, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.Title.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Description.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.ExpenseType.ToString().Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Frequency.ToString().Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    };

    protected override async Task OnInitializedAsync()
    {
        loadingData = true;

        expenses = await db.Expenses
            .AsNoTracking()
            .OrderByDescending(x => x.Created)
            .ToListAsync();

        loadingData = false;
    }

    private async Task OpenBillImage(Expense item)
    {
        var parameters = new DialogParameters<BillingImageDialog>
        {
            { x => x.ImagePath, item.BillImagePath }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            CloseButton = true,
            CloseOnEscapeKey = true,
            FullWidth = true
        };

        await DialogService.ShowAsync<BillingImageDialog>($"{item.Title} ({item.Amount.AsCurrency()})", parameters, options);
    }
}