@page "/invoices/view/{Id:int}"

@attribute [Authorize(Roles = Role.SuperAdmin)]

@inject ApplicationDbContext Db
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Invoice - @(_inv?.InvoiceNumber ?? "")</PageTitle>

<div class="no-print mb-2 invoice-actions">
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/invoices">
        Back to List
    </MudButton>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit"
               Href="@($"/invoices/edit/{Id}")">
        Edit
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.Print"
               OnClick="@Print" Style="float:right">
        Print / Save PDF
    </MudButton>
    <MudButton Variant="Variant.Outlined"
               StartIcon="@(_showBankDetails ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
               OnClick="@ToggleBankDetails"
               Color="Color.Info"
               Style="float:right; margin-right:8px">
        @(_showBankDetails ? "Hide" : "Show") Bank Details
    </MudButton>
</div>

@if (_inv is not null)
{
    <div id="invoice-print-area" class="invoice-document">
        <div class="header">
            <div class="company-info">
                <div class="company-name">@_inv.CompanyName</div>
                @if (!string.IsNullOrWhiteSpace(_inv.CompanyAddress))
                {
                    <div class="company-detail">@_inv.CompanyAddress</div>
                }
                @if (!string.IsNullOrWhiteSpace(_inv.CompanyPhone))
                {
                    <div class="company-detail">@_inv.CompanyPhone</div>
                }
                @if (!string.IsNullOrWhiteSpace(_inv.CompanyEmail))
                {
                    <div class="company-detail">@_inv.CompanyEmail</div>
                }
                @if (!string.IsNullOrWhiteSpace(_inv.CompanyPan))
                {
                    <div class="company-detail">PAN: @_inv.CompanyPan</div>
                }
            </div>
            <div class="title-section">
                <div class="title">INVOICE</div>
                <div class="meta">
                    <div class="meta-row">
                        <span class="meta-label">Invoice #:</span>
                        <span class="meta-value">@_inv.InvoiceNumber</span>
                    </div>
                    <div class="meta-row">
                        <span class="meta-label">Date:</span>
                        <span class="meta-value">@_inv.InvoiceDate.ToString("yyyy-MM-dd")</span>
                    </div>
                    <div class="meta-row">
                        <span class="meta-label">Due Date:</span>
                        <span class="meta-value">@(_inv.DueDate?.ToString("yyyy-MM-dd") ?? "N/A")</span>
                    </div>
                    <div class="meta-row">
                        <span class="meta-label">Currency:</span>
                        <span class="meta-value">@_inv.Currency</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="divider"></div>

        <div class="client-section">
            <div class="section-label">Bill To:</div>
            <div class="client-name">@_inv.ClientName</div>
            @if (!string.IsNullOrWhiteSpace(_inv.ClientAddress))
            {
                <div class="client-detail">@_inv.ClientAddress</div>
            }
            @if (!string.IsNullOrWhiteSpace(_inv.ClientEmail))
            {
                <div class="client-detail">@_inv.ClientEmail</div>
            }
            @if (!string.IsNullOrWhiteSpace(_inv.ClientPhone))
            {
                <div class="client-detail">@_inv.ClientPhone</div>
            }
        </div>

        <table class="items-table">
            <thead>
                <tr>
                    <th class="col-sno">#</th>
                    <th class="col-desc">Particulars</th>
                    <th class="col-cat">Category</th>
                    <th class="col-qty">Qty</th>
                    <th class="col-rate">Rate</th>
                    <th class="col-amount">Amount</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var items = _inv.Items.OrderBy(i => i.SortOrder).ToList();
                    string? currentCategory = null;
                    int sno = 0;
                    foreach (var item in items)
                    {
                        sno++;
                        if (item.Category != currentCategory)
                        {
                            currentCategory = item.Category;
                            <tr class="category-row">
                                <td colspan="6">@currentCategory</td>
                            </tr>
                        }
                        <tr>
                            <td class="text-center">@sno</td>
                            <td>@item.Description</td>
                            <td>@item.Category</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-right">@FormatAmount(item.UnitPrice)</td>
                            <td class="text-right">@FormatAmount(item.Quantity * item.UnitPrice)</td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="totals-section">
            <div class="totals-table">
                <div class="total-row">
                    <span>Subtotal:</span>
                    <span>@FormatAmount(Subtotal)</span>
                </div>
                @if (_inv.DiscountPercent > 0)
                {
                    <div class="total-row">
                        <span>Discount (@_inv.DiscountPercent%):</span>
                        <span>@FormatAmount(DiscountAmount)</span>
                    </div>
                }
                @if (_inv.TaxPercent > 0)
                {
                    <div class="total-row">
                        <span>Tax / VAT (@_inv.TaxPercent%):</span>
                        <span>@FormatAmount(TaxAmount)</span>
                    </div>
                }
                <div class="total-row grand-total">
                    <span>Grand Total:</span>
                    <span>@FormatAmount(GrandTotal)</span>
                </div>
                <div class="total-row grand-total-words">
                    <span colspan="2">@AmountInWords(GrandTotal) @_inv.Currency only</span>
                </div>
            </div>
        </div>

        @if (_showBankDetails && (!string.IsNullOrWhiteSpace(_inv.BankName) ||
             !string.IsNullOrWhiteSpace(_inv.BankAccountNumber) ||
             !string.IsNullOrWhiteSpace(_inv.BankAccountHolder)))
        {
            <div class="bank-section">
                <div class="section-label">Bank Details:</div>
                @if (!string.IsNullOrWhiteSpace(_inv.BankAccountHolder))
                {
                    <div class="bank-detail">Account Holder: @_inv.BankAccountHolder</div>
                }
                @if (!string.IsNullOrWhiteSpace(_inv.BankName))
                {
                    <div class="bank-detail">Bank: @_inv.BankName</div>
                }
                @if (!string.IsNullOrWhiteSpace(_inv.BankAccountNumber))
                {
                    <div class="bank-detail">Account #: @_inv.BankAccountNumber</div>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_inv.Notes))
        {
            <div class="notes-section">
                <div class="section-label">Notes:</div>
                <div class="notes-text">@_inv.Notes</div>
            </div>
        }
    </div>
}
else if (!_notFound)
{
    <MudAlert Severity="Severity.Info">Loading...</MudAlert>
}
else
{
    <MudAlert Severity="Severity.Error">Invoice not found.</MudAlert>
}

<style>
    @@media print {
        @@page { margin: 15mm; }
        * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        body { background: white; }
        .no-print { display: none !important; }
        .mud-layout { height: auto !important; }
    }

    .invoice-document {
        background: white;
        padding: 20px 40px;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #222;
        max-width: 900px;
        margin: 0 auto;
        border: 1px solid #ddd;
        border-radius: 4px;
    }

    .invoice-actions {
        background: white;
        padding-top: 5px;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #222;
        max-width: 900px;
        margin: 0 auto;
    }

    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; }
    .company-name { font-size: 20px; font-weight: 700; color: #1a237e; }
    .company-detail { font-size: 12px; color: #555; }
    .title-section { text-align: right; }
    .title { font-size: 28px; font-weight: 700; color: #1a237e; letter-spacing: 2px; }
    .meta { margin-top: 8px; }
    .meta-row { margin-bottom: 4px; font-size: 13px; }
    .meta-label { color: #666; margin-right: 6px; }
    .meta-value { font-weight: 600; }
    .divider { border-top: 2px solid #1a237e; margin-bottom: 14px; }

    .client-section { margin-bottom: 15px; }
    .section-label { font-weight: 700; font-size: 14px; color: #1a237e; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 1px; }
    .client-name { font-size: 16px; font-weight: 600; }
    .client-detail { font-size: 13px; color: #555; }

    .items-table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
    .items-table th { background: #1a237e; color: white; padding: 10px 8px; font-size: 13px; text-align: left; }
    .items-table td { padding: 7px; font-size: 13px; border-bottom: 1px solid #e0e0e0; }
    .items-table tbody tr:hover { background: #f9f9f9; }
    .col-sno { width: 40px; text-align: center; }
    .col-cat { width: 100px; }
    .col-qty { width: 60px; text-align: center; }
    .col-rate { width: 100px; text-align: right; }
    .col-amount { width: 120px; text-align: right; }
    .category-row td { font-weight: 700; font-size: 12px; text-transform: uppercase; color: #1a237e; letter-spacing: 1px; background: #f0f0f0; }
    .text-center { text-align: center; }
    .text-right { text-align: right; }

    .totals-section { display: flex; justify-content: flex-end; margin-bottom: 24px; }
    .totals-table { width: 380px; }
    .total-row { display: flex; justify-content: space-between; padding: 4px 0; font-size: 14px; }
    .grand-total { font-weight: 700; font-size: 18px; border-top: 2px solid #333; padding-top: 8px; margin-top: 4px; color: #1a237e; }
    .grand-total-words { font-size: 12px; font-weight: 400; color: #666; font-style: italic; border: none; padding-top: 2px; margin-top: 0; }

    .bank-section { margin-bottom: 15px; padding: 10px 14px; background: #f5f5f5; border-radius: 4px; }
    .bank-detail { font-size: 13px; color: #444; }

    .terms-section, .notes-section { margin-bottom: 10px; }
    .terms-text, .notes-text { font-size: 13px; color: #444; white-space: pre-wrap; }
</style>

@code {
    [Parameter] public int Id { get; set; }

    private Invoice? _inv;
    private bool _notFound;
    private bool _showBankDetails = true;

    private float Subtotal => _inv?.Items.Sum(i => i.Quantity * i.UnitPrice) ?? 0;
    private float DiscountAmount => Subtotal * (_inv?.DiscountPercent ?? 0) / 100;
    private float TaxableAmount => Subtotal - DiscountAmount;
    private float TaxAmount => TaxableAmount * (_inv?.TaxPercent ?? 0) / 100;
    private float GrandTotal => TaxableAmount + TaxAmount;

    private string FormatAmount(float amount) => $"{_inv?.Currency ?? "NPR"} {amount:N2}";

    protected override async Task OnInitializedAsync()
    {
        _inv = await Db.Invoices
            .Include(x => x.Items)
            .AsNoTracking()
            .FirstOrDefaultAsync(x => x.Id == Id);

        _notFound = _inv is null;
    }

    private void ToggleBankDetails()
    {
        _showBankDetails = !_showBankDetails;
    }

    private async Task Print()
    {
        await JS.InvokeVoidAsync("printQuotation", "invoice-print-area");
    }

    private static string AmountInWords(float amount)
    {
        int whole = (int)Math.Floor(amount);
        if (whole <= 0) return "Zero";
        return NumberToWords(whole);
    }

    private static string NumberToWords(int num)
    {
        if (num == 0) return "Zero";
        if (num < 0) return "Minus " + NumberToWords(-num);

        string[] ones = ["", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine",
                         "Ten", "Eleven", "Twelve", "Thirteen", "Fourteen", "Fifteen", "Sixteen",
                         "Seventeen", "Eighteen", "Nineteen"];
        string[] tens = ["", "", "Twenty", "Thirty", "Forty", "Fifty", "Sixty", "Seventy", "Eighty", "Ninety"];

        if (num >= 1000000)
        {
            return $"{NumberToWords(num / 1000000)} Million {NumberToWords(num % 1000000)}".Trim();
        }

        if (num >= 1000)
        {
            return $"{NumberToWords(num / 1000)} Thousand {NumberToWords(num % 1000)}".Trim();
        }

        if (num >= 100)
        {
            return $"{NumberToWords(num / 100)} Hundred {NumberToWords(num % 100)}".Trim();
        }

        if (num >= 20)
        {
            return $"{tens[num / 10]} {ones[num % 10]}".Trim();
        }

        return ones[num];
    }
}
