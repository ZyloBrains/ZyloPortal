@page "/invoices/add"
@page "/invoices/edit/{Id:int}"

@attribute [Authorize(Roles = Role.SuperAdmin)]

@inject ApplicationDbContext Db
@inject ISnackbar SnackBar
@inject NavigationManager Navigation

<PageTitle>@(IsAdd ? "New" : "Edit") Invoice</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
        <MudCard Class="pa-4 mb-4">
            <MudText Typo="Typo.h6">@(IsAdd ? "Create" : "Edit") Invoice</MudText>

            <div class="d-flex gap-4 mt-4">
                <MudSelect @bind-Value="_selectedTemplate"
                           @bind-Value:after="OnTemplateApplied"
                           Label="Start from template"
                           Variant="Variant.Outlined"
                           Class="flex-1"
                           Clearable="true"
                           Disabled="@(!IsAdd)">
                    @foreach (var tpl in _templates)
                    {
                        <MudSelectItem Value="@tpl.Key">@tpl.Key</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect @bind-Value="model.PaymentStatus"
                           Label="Payment Status"
                           Variant="Variant.Outlined"
                           Class="flex-1">
                    <MudSelectItem Value="@("Unpaid")">Unpaid</MudSelectItem>
                    <MudSelectItem Value="@("Paid")">Paid</MudSelectItem>
                    <MudSelectItem Value="@("Partial")">Partial</MudSelectItem>
                    <MudSelectItem Value="@("Overdue")">Overdue</MudSelectItem>
                    <MudSelectItem Value="@("Cancelled")">Cancelled</MudSelectItem>
                </MudSelect>
            </div>

            <MudTextField Label="Currency"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.Currency"
                          Placeholder="NPR / USD / INR" />

            <MudTextField Label="Client Name"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.ClientName"
                          Required="true"
                          RequiredError="Client name is required" />

            <MudTextField Label="Client Address"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.ClientAddress" />

            <MudTextField Label="Client Email"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.ClientEmail" />

            <MudTextField Label="Client Phone"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.ClientPhone" />

            <div class="d-flex gap-4 mt-4">
                <MudDatePicker Label="Invoice Date" @bind-Date="model.InvoiceDate" Variant="Variant.Outlined" Class="flex-1" />
                <MudDatePicker Label="Due Date" @bind-Date="model.DueDate" Variant="Variant.Outlined" Class="flex-1" />
            </div>
        </MudCard>

        <MudCard Class="pa-4 mb-4">
            <MudText Typo="Typo.subtitle2">Your Company (ZyloBrains)</MudText>

            <MudTextField Label="Company Name"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.CompanyName" />

            <MudTextField Label="Company Address"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.CompanyAddress" />

            <MudTextField Label="Company Phone"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.CompanyPhone" />

            <MudTextField Label="Company Email"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.CompanyEmail" />

            <MudTextField Label="Company PAN / Tax ID"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.CompanyPan" />
        </MudCard>

        <MudCard Class="pa-4 mb-4">
            <MudText Typo="Typo.subtitle2">Bank Details</MudText>

            <MudTextField Label="Bank Name"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.BankName" />

            <MudTextField Label="Account Number"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.BankAccountNumber" />

            <MudTextField Label="Account Holder Name"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.BankAccountHolder" />
        </MudCard>

        <MudCard Class="pa-4 mb-4">
            <div class="d-flex align-center mb-4">
                <MudText Typo="Typo.h6" Class="flex-1">Items</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="@AddItem">
                    Add Item
                </MudButton>
            </div>

            <MudSimpleTable>
                <thead>
                    <tr>
                        <th style="width:40%">Particulars</th>
                        <th style="width:15%">Category</th>
                        <th style="width:10%">Qty</th>
                        <th style="width:15%">Rate (@model.Currency)</th>
                        <th style="width:15%">Total (@model.Currency)</th>
                        <th style="width:5%"></th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < model.Items.Count; i++)
                    {
                        var idx = i;
                        var item = model.Items[i];
                        <tr>
                            <td>
                                <MudTextField @bind-Value="item.Description" Placeholder="Description" Variant="Variant.Outlined" Class="my-0" />
                            </td>
                            <td>
                                <MudSelect @bind-Value="item.Category" Placeholder="Category" Variant="Variant.Outlined" Dense="true" Class="my-0">
                                    <MudSelectItem Value="@("Marketing")">Marketing</MudSelectItem>
                                    <MudSelectItem Value="@("Content")">Content</MudSelectItem>
                                    <MudSelectItem Value="@("Design")">Design</MudSelectItem>
                                    <MudSelectItem Value="@("Development")">Development</MudSelectItem>
                                    <MudSelectItem Value="@("Hosting")">Hosting</MudSelectItem>
                                    <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td>
                                <MudNumericField @bind-Value="item.Quantity" Min="1" Variant="Variant.Outlined" Class="my-0" />
                            </td>
                            <td>
                                <MudNumericField @bind-Value="item.UnitPrice" Min="0" Variant="Variant.Outlined" Class="my-0"
                                                 Adornment="Adornment.Start" AdornmentText="@model.Currency" />
                            </td>
                            <td class="text-right">
                                @($"{item.Total:N2}")
                            </td>
                            <td>
                                <MudIconButton Icon="@Icons.Material.Filled.RemoveCircle" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => RemoveItem(idx))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>

            @if (model.Items.Count > 0)
            {
                <div class="d-flex flex-column align-end mt-4" style="min-width:300px; margin-left:auto">
                    <div class="d-flex justify-between" style="width:300px">
                        <span>Subtotal:</span>
                        <span>@($"{model.Currency} {model.Subtotal:N2}")</span>
                    </div>
                    <div class="d-flex align-center mt-2" style="width:300px">
                        <span class="flex-1">Discount:</span>
                        <MudNumericField @bind-Value="model.DiscountPercent" Min="0" Max="100" Variant="Variant.Outlined"
                                         Class="my-0" Style="width:80px" Adornment="Adornment.End" AdornmentText="%" />
                        <span style="width:100px; text-align:right">@($"{model.Currency} {model.DiscountAmount:N2}")</span>
                    </div>
                    <div class="d-flex align-center mt-2" style="width:300px">
                        <span class="flex-1">Tax / VAT:</span>
                        <MudNumericField @bind-Value="model.TaxPercent" Min="0" Max="100" Variant="Variant.Outlined"
                                         Class="my-0" Style="width:80px" Adornment="Adornment.End" AdornmentText="%" />
                        <span style="width:100px; text-align:right">@($"{model.Currency} {model.TaxAmount:N2}")</span>
                    </div>
                    <MudDivider Class="my-1" Style="width:300px" />
                    <div class="d-flex justify-between" style="width:300px; font-weight:bold; font-size:1.1em">
                        <span>Grand Total:</span>
                        <span>@($"{model.Currency} {model.GrandTotal:N2}")</span>
                    </div>
                </div>
            }
        </MudCard>

        <MudCard Class="pa-4 mb-4">
            <MudTextField Label="Payment Terms"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.PaymentTerms" />

            <MudTextField Label="Notes"
                          Variant="Variant.Outlined"
                          Class="mt-4"
                          @bind-Value="model.Notes" />
        </MudCard>

        <div class="d-flex gap-4 mt-4 mb-8">
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Tertiary"
                       StartIcon="@Icons.Material.Filled.Save">
                @(IsAdd ? "Create Invoice" : "Update Invoice")
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Href="/invoices"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Cancel
            </MudButton>
        </div>
    </EditForm>
</MudContainer>

@code {
    [Parameter] public int? Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthTask { get; set; } = null!;

    private InvoiceEditViewModel model = new();
    private bool IsAdd => Id is null or 0;
    private string _selectedTemplate = "";

    private Dictionary<string, List<InvoiceItemEdit>> _templates = new()
    {
        ["Digital Marketing"] = new()
        {
            new() { Description = "Social Media Boosting", Category = "Marketing", Quantity = 1, UnitPrice = 5000, SortOrder = 1 },
            new() { Description = "Content Creation", Category = "Content", Quantity = 1, UnitPrice = 8000, SortOrder = 2 },
            new() { Description = "Graphic Design", Category = "Design", Quantity = 1, UnitPrice = 6000, SortOrder = 3 },
            new() { Description = "SEO Optimization", Category = "Marketing", Quantity = 1, UnitPrice = 7000, SortOrder = 4 },
            new() { Description = "Social Media Management", Category = "Marketing", Quantity = 1, UnitPrice = 10000, SortOrder = 5 },
            new() { Description = "Analytics & Reporting", Category = "Marketing", Quantity = 1, UnitPrice = 4000, SortOrder = 6 },
            new() { Description = "Email Marketing Campaign", Category = "Marketing", Quantity = 1, UnitPrice = 5000, SortOrder = 7 },
            new() { Description = "Website Maintenance", Category = "Other", Quantity = 1, UnitPrice = 3000, SortOrder = 8 },
        },
        ["Website Project"] = new()
        {
            new() { Description = "Domain Registration (1 Year)", Category = "Other", Quantity = 1, UnitPrice = 1200, SortOrder = 1 },
            new() { Description = "Web Hosting (1 Year)", Category = "Hosting", Quantity = 1, UnitPrice = 5000, SortOrder = 2 },
            new() { Description = "UI/UX Design", Category = "Design", Quantity = 1, UnitPrice = 15000, SortOrder = 3 },
            new() { Description = "Frontend Development", Category = "Development", Quantity = 1, UnitPrice = 25000, SortOrder = 4 },
            new() { Description = "Backend Development", Category = "Development", Quantity = 1, UnitPrice = 30000, SortOrder = 5 },
            new() { Description = "Annual Maintenance (1 Year)", Category = "Hosting", Quantity = 1, UnitPrice = 12000, SortOrder = 6 },
        }
    };

    protected override async Task OnInitializedAsync()
    {
        if (!IsAdd)
        {
            var inv = await Db.Invoices
                .Include(x => x.Items.OrderBy(i => i.SortOrder))
                .FirstOrDefaultAsync(x => x.Id == Id);

            if (inv is not null)
            {
                model = new()
                {
                    Id = inv.Id,
                    ClientName = inv.ClientName,
                    ClientAddress = inv.ClientAddress,
                    ClientEmail = inv.ClientEmail,
                    ClientPhone = inv.ClientPhone,
                    CompanyName = inv.CompanyName,
                    CompanyAddress = inv.CompanyAddress,
                    CompanyPhone = inv.CompanyPhone,
                    CompanyEmail = inv.CompanyEmail,
                    CompanyPan = inv.CompanyPan,
                    BankName = inv.BankName,
                    BankAccountNumber = inv.BankAccountNumber,
                    BankAccountHolder = inv.BankAccountHolder,
                    Currency = inv.Currency,
                    InvoiceDate = inv.InvoiceDate,
                    DueDate = inv.DueDate,
                    DiscountPercent = inv.DiscountPercent,
                    TaxPercent = inv.TaxPercent,
                    PaymentStatus = inv.PaymentStatus,
                    PaymentTerms = inv.PaymentTerms,
                    Notes = inv.Notes,
                    Items = inv.Items.Select(i => new InvoiceItemEdit
                    {
                        Id = i.Id,
                        Description = i.Description,
                        Category = i.Category,
                        Quantity = i.Quantity,
                        UnitPrice = i.UnitPrice,
                        SortOrder = i.SortOrder
                    }).ToList()
                };
            }
        }
    }

    private void OnTemplateApplied()
    {
        ApplyTemplate(_selectedTemplate);
    }

    private void ApplyTemplate(string templateName)
    {
        _selectedTemplate = templateName;
        if (_templates.TryGetValue(templateName, out var items))
        {
            model.Items = items.Select(i => new InvoiceItemEdit
            {
                Description = i.Description,
                Category = i.Category,
                Quantity = i.Quantity,
                UnitPrice = i.UnitPrice,
                SortOrder = i.SortOrder
            }).ToList();
        }
    }

    private void AddItem()
    {
        model.Items.Add(new InvoiceItemEdit
        {
            Description = "",
            Category = "Other",
            Quantity = 1,
            SortOrder = model.Items.Count > 0 ? model.Items.Max(i => i.SortOrder) + 1 : 1
        });
    }

    private void RemoveItem(int index)
    {
        model.Items.RemoveAt(index);
    }

    private async Task OnValidSubmit()
    {
        var authState = await AuthTask;
        var user = authState.User.Identity?.Name ?? "System";

        if (IsAdd)
        {
            var yearPrefix = $"INV-{DateTime.Now.Year}-";
            var lastNumber = await Db.Invoices
                .Where(q => q.InvoiceNumber.StartsWith(yearPrefix))
                .CountAsync();
            var seq = (lastNumber + 1).ToString("D3");

            var entity = new Invoice
            {
                InvoiceNumber = $"INV-{DateTime.Now.Year}-{seq}",
                ClientName = model.ClientName,
                ClientAddress = model.ClientAddress,
                ClientEmail = model.ClientEmail,
                ClientPhone = model.ClientPhone,
                CompanyName = model.CompanyName,
                CompanyAddress = model.CompanyAddress,
                CompanyPhone = model.CompanyPhone,
                CompanyEmail = model.CompanyEmail,
                CompanyPan = model.CompanyPan,
                BankName = model.BankName,
                BankAccountNumber = model.BankAccountNumber,
                BankAccountHolder = model.BankAccountHolder,
                Currency = model.Currency,
                InvoiceDate = model.InvoiceDate ?? DateTime.Now,
                DueDate = model.DueDate,
                DiscountPercent = model.DiscountPercent,
                TaxPercent = model.TaxPercent,
                PaymentStatus = model.PaymentStatus,
                PaymentTerms = model.PaymentTerms,
                Notes = model.Notes,
                Items = model.Items.Select(i => new InvoiceItem
                {
                    Description = i.Description,
                    Category = i.Category,
                    Quantity = i.Quantity,
                    UnitPrice = i.UnitPrice,
                    SortOrder = i.SortOrder
                }).ToList()
            }.AddCreatedStamps(user) as Invoice;

            Db.Invoices.Add(entity!);
        }
        else
        {
            var entity = await Db.Invoices
                .Include(x => x.Items)
                .FirstOrDefaultAsync(x => x.Id == Id);

            if (entity is null) return;

            entity.ClientName = model.ClientName;
            entity.ClientAddress = model.ClientAddress;
            entity.ClientEmail = model.ClientEmail;
            entity.ClientPhone = model.ClientPhone;
            entity.CompanyName = model.CompanyName;
            entity.CompanyAddress = model.CompanyAddress;
            entity.CompanyPhone = model.CompanyPhone;
            entity.CompanyEmail = model.CompanyEmail;
            entity.CompanyPan = model.CompanyPan;
            entity.BankName = model.BankName;
            entity.BankAccountNumber = model.BankAccountNumber;
            entity.BankAccountHolder = model.BankAccountHolder;
            entity.Currency = model.Currency;
            entity.InvoiceDate = model.InvoiceDate ?? DateTime.Now;
            entity.DueDate = model.DueDate;
            entity.DiscountPercent = model.DiscountPercent;
            entity.TaxPercent = model.TaxPercent;
            entity.PaymentStatus = model.PaymentStatus;
            entity.PaymentTerms = model.PaymentTerms;
            entity.Notes = model.Notes;
            entity.AddLastUpdatedStamps(user);

            Db.InvoiceItems.RemoveRange(entity.Items);
            entity.Items = model.Items.Select(i => new InvoiceItem
            {
                Description = i.Description,
                Category = i.Category,
                Quantity = i.Quantity,
                UnitPrice = i.UnitPrice,
                SortOrder = i.SortOrder
            }).ToList();
        }

        await Db.SaveChangesAsync();
        SnackBar.Add(IsAdd ? "Invoice created" : "Invoice updated", Severity.Success);
        Navigation.NavigateTo("/invoices");
    }
}
