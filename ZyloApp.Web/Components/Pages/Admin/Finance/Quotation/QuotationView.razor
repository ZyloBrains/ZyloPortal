@page "/quotations/view/{Id:int}"

@attribute [Authorize(Roles = Role.SuperAdmin)]

@inject ApplicationDbContext Db
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Quotation - @(_quote?.QuoteNumber ?? "")</PageTitle>

<div class="no-print mb-2 quotation-actions">
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/quotations">
        Back to List
    </MudButton>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit"
               Href="@($"/quotations/edit/{Id}")">
        Edit
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.Print"
               OnClick="@Print" Style="float:right">
        Print / Save PDF
    </MudButton>
</div>

@if (_quote is not null)
{
    <div id="quotation-print-area" class="quotation-document">
        <div class="header">
            <div class="title">QUOTATION</div>
            <div class="meta">
                <div class="meta-row">
                    <span class="meta-label">Quote #:</span>
                    <span class="meta-value">@_quote.QuoteNumber</span>
                </div>
                <div class="meta-row">
                    <span class="meta-label">Date:</span>
                    <span class="meta-value">@_quote.QuoteDate.ToString("yyyy-MM-dd")</span>
                </div>
                <div class="meta-row">
                    <span class="meta-label">Valid Until:</span>
                    <span class="meta-value">@(_quote.ValidUntil?.ToString("yyyy-MM-dd") ?? "N/A")</span>
                </div>
                <div class="meta-row">
                    <span class="meta-label">Currency:</span>
                    <span class="meta-value">@_quote.Currency</span>
                </div>
            </div>
        </div>

        <div class="client-section">
            <div class="section-label">Bill To:</div>
            <div class="client-name">@_quote.ClientName</div>
            @if (!string.IsNullOrWhiteSpace(_quote.ClientAddress))
            {
                <div class="client-detail">@_quote.ClientAddress</div>
            }
            @if (!string.IsNullOrWhiteSpace(_quote.ClientEmail))
            {
                <div class="client-detail">@_quote.ClientEmail</div>
            }
            @if (!string.IsNullOrWhiteSpace(_quote.ClientPhone))
            {
                <div class="client-detail">@_quote.ClientPhone</div>
            }
        </div>

        <div class="project-section">
            <span class="section-label">Project:</span> @_quote.ProjectName
        </div>

        <table class="items-table">
            <thead>
                <tr>
                    <th class="col-sno">#</th>
                    <th class="col-desc">Particulars</th>
                    <th class="col-cat">Category</th>
                    <th class="col-qty">Qty</th>
                    <th class="col-rate">Rate</th>
                    <th class="col-amount">Amount</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var items = _quote.Items.OrderBy(i => i.SortOrder).ToList();
                    string? currentCategory = null;
                    int sno = 0;
                    foreach (var item in items)
                    {
                        sno++;
                        if (item.Category != currentCategory)
                        {
                            currentCategory = item.Category;
                            <tr class="category-row">
                                <td colspan="6">@currentCategory</td>
                            </tr>
                        }
                        <tr>
                            <td class="text-center">@sno</td>
                            <td>@item.Description</td>
                            <td>@item.Category</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-right">@FormatAmount(item.UnitPrice)</td>
                            <td class="text-right">@FormatAmount(item.Quantity * item.UnitPrice)</td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="totals-section">
            <div class="totals-table">
                <div class="total-row">
                    <span>Subtotal:</span>
                    <span>@FormatAmount(Subtotal)</span>
                </div>
                @if (_quote.DiscountPercent > 0)
                {
                    <div class="total-row">
                        <span>Discount (@_quote.DiscountPercent%):</span>
                        <span>@FormatAmount(DiscountAmount)</span>
                    </div>
                }
                @if (_quote.TaxPercent > 0)
                {
                    <div class="total-row">
                        <span>Tax (@_quote.TaxPercent%):</span>
                        <span>@FormatAmount(TaxAmount)</span>
                    </div>
                }
                <div class="total-row grand-total">
                    <span>Grand Total:</span>
                    <span>@FormatAmount(GrandTotal)</span>
                </div>
                <div class="total-row grand-total-words">
                    <span colspan="2">@AmountInWords(GrandTotal) @_quote.Currency only</span>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_quote.PaymentTerms))
        {
            <div class="terms-section">
                <div class="section-label">Payment Terms:</div>
                <div class="terms-text">@_quote.PaymentTerms</div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_quote.Notes))
        {
            <div class="notes-section">
                <div class="section-label">Notes:</div>
                <div class="notes-text">@_quote.Notes</div>
            </div>
        }
    </div>
}
else if (!_notFound)
{
    <MudAlert Severity="Severity.Info">Loading...</MudAlert>
}
else
{
    <MudAlert Severity="Severity.Error">Quotation not found.</MudAlert>
}

<style>
    @@media print {
        @@page { margin: 15mm; }
        * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        body { background: white; }
        .no-print { display: none !important; }
        .mud-layout { height: auto !important; }
    }

    .quotation-document {
        background: white;
        padding: 20px 40px;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #222;
        max-width: 900px;
        margin: 0 auto;
        border: 1px solid #ddd;
        border-radius: 4px;
    }

    .quotation-actions {
        background: white;
        padding-top: 5px;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #222;
        max-width: 900px;
        margin: 0 auto;
    }

    .header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 14px; }
    .title { font-size: 28px; font-weight: 700; color: #1a237e; letter-spacing: 2px; }
    .meta { text-align: right; }
    .meta-row { margin-bottom: 4px; font-size: 13px; }
    .meta-label { color: #666; margin-right: 6px; }
    .meta-value { font-weight: 600; }

    .client-section { margin-bottom: 15px; }
    .section-label { font-weight: 700; font-size: 14px; color: #1a237e; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 1px; }
    .client-name { font-size: 16px; font-weight: 600; }
    .client-detail { font-size: 13px; color: #555; }

    .project-section { margin-bottom: 15px; padding: 10px 14px; background: #f5f5f5; border-radius: 4px; font-size: 14px; }

    .items-table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
    .items-table th { background: #1a237e; color: white; padding: 10px 8px; font-size: 13px; text-align: left; }
    .items-table td { padding: 7px; font-size: 13px; border-bottom: 1px solid #e0e0e0; }
    .items-table tbody tr:hover { background: #f9f9f9; }
    .col-sno { width: 40px; text-align: center; }
    .col-desc { }
    .col-cat { width: 100px; }
    .col-qty { width: 60px; text-align: center; }
    .col-rate { width: 100px; text-align: right; }
    .col-amount { width: 120px; text-align: right; }
    .category-row td { font-weight: 700; font-size: 12px; text-transform: uppercase; color: #1a237e; letter-spacing: 1px; background: #f0f0f0; }
    .text-center { text-align: center; }
    .text-right { text-align: right; }

    .totals-section { display: flex; justify-content: flex-end; margin-bottom: 24px; }
    .totals-table { width: 380px; }
    .total-row { display: flex; justify-content: space-between; padding: 4px 0; font-size: 14px; }
    .grand-total { font-weight: 700; font-size: 18px; border-top: 2px solid #333; padding-top: 8px; margin-top: 4px; color: #1a237e; }
    .grand-total-words { font-size: 12px; font-weight: 400; color: #666; font-style: italic; border: none; padding-top: 2px; margin-top: 0; }

    .terms-text, .notes-text { font-size: 13px; color: #444; white-space: pre-wrap; }

</style>

@code {
    [Parameter] public int Id { get; set; }

    private Quotation? _quote;
    private bool _notFound;

    private float Subtotal => _quote?.Items.Sum(i => i.Quantity * i.UnitPrice) ?? 0;
    private float DiscountAmount => Subtotal * (_quote?.DiscountPercent ?? 0) / 100;
    private float TaxableAmount => Subtotal - DiscountAmount;
    private float TaxAmount => TaxableAmount * (_quote?.TaxPercent ?? 0) / 100;
    private float GrandTotal => TaxableAmount + TaxAmount;

    private string FormatAmount(float amount) => $"{_quote?.Currency ?? "NPR"} {amount:N2}";

    protected override async Task OnInitializedAsync()
    {
        _quote = await Db.Quotations
            .Include(x => x.Items)
            .AsNoTracking()
            .FirstOrDefaultAsync(x => x.Id == Id);

        _notFound = _quote is null;
    }

    private async Task Print()
    {
        await JS.InvokeVoidAsync("printQuotation", "quotation-print-area");
    }

    private static string AmountInWords(float amount)
    {
        int whole = (int)Math.Floor(amount);
        if (whole <= 0) return "Zero";
        return NumberToWords(whole);
    }

    private static string NumberToWords(int num)
    {
        if (num == 0) return "Zero";
        if (num < 0) return "Minus " + NumberToWords(-num);

        string[] ones = ["", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine",
                         "Ten", "Eleven", "Twelve", "Thirteen", "Fourteen", "Fifteen", "Sixteen",
                         "Seventeen", "Eighteen", "Nineteen"];
        string[] tens = ["", "", "Twenty", "Thirty", "Forty", "Fifty", "Sixty", "Seventy", "Eighty", "Ninety"];

        var words = new List<string>();

        if (num >= 1000000)
        {
            words.Add($"{NumberToWords(num / 1000000)} Million");
            num %= 1000000;
        }

        if (num >= 1000)
        {
            words.Add($"{NumberToWords(num / 1000)} Thousand");
            num %= 1000;
        }

        if (num >= 100)
        {
            words.Add($"{NumberToWords(num / 100)} Hundred");
            num %= 100;
        }

        if (num >= 20)
        {
            words.Add(tens[num / 10]);
            num %= 10;
        }

        if (num > 0)
        {
            words.Add(ones[num]);
        }

        return string.Join(" ", words);
    }
}
