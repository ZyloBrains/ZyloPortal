@page "/revenue/add"

@attribute [Authorize(Roles = Role.SuperAdmin)]

@inject ApplicationDbContext Db
@inject ISnackbar SnackBar

<PageTitle>New Revenue Source</PageTitle>

<MudContainer>
    <EditForm Model="@model" OnValidSubmit="OnValidSubmit">

        <MudTextField Variant="Variant.Outlined" Label="Particulars" Class="mt-4" @bind-Value="model.Particulars" />
        <MudSelect Variant="Variant.Outlined"
                   @bind-Value="model.Source"
                   Label="Source"
                   Class="mt-4">
            @foreach (var item in Enum.GetValues<RevenueSource>())
            {
                <MudSelectItem Value="@item">@item</MudSelectItem>
            }
        </MudSelect>
        <MudNumericField Variant="Variant.Outlined" Label="Amount" Class="mt-4" @bind-Value="model.Amount" />
        <MudDatePicker Label="Date" @bind-Date="model.Date" Class="mt-4" Variant="Variant.Outlined" />
        <MudSelect Variant="Variant.Outlined"
                   @bind-Value="model.Frequency"
                   Label="Frequency"
                   Class="mt-4">
            @foreach (var item in Enum.GetValues<Frequency>())
            {
                <MudSelectItem Value="@item">@item</MudSelectItem>
            }
        </MudSelect>

        @if (model.Source == RevenueSource.ProjectWork)
        {
            <MudSelect Variant="Variant.Outlined"
                       @bind-Value="model.ProjectId"
                       Label="Project"
                       Class="mt-4"
                       Required="true"
                       RequiredErrorText="Project is required for ProjectWork source">
                @foreach (var project in _projects)
                {
                    <MudSelectItem T="int?" Value="@project.Id">@project.Title</MudSelectItem>
                }
            </MudSelect>
        }
        else
        {
            model.ProjectId = null;
        }

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Tertiary"
                   Class="mt-4"
                   StartIcon="@Icons.Material.Filled.Save">
            Add Revenue
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Class="mt-3 ml-3"
                   Href="/revenues"
                   StartIcon="@Icons.Material.Filled.ArrowBack">
            Navigate to Revenue Sources
        </MudButton>
    </EditForm>
</MudContainer>

@code {

    [CascadingParameter]
    private Task<AuthenticationState> AuthTask { get; set; } = null!;

    Revenue model = new() { Amount = 0.0f, Date = DateTime.Now };
    private List<Project> _projects = [];

    protected override async Task OnInitializedAsync()
    {
        _projects = await Db.Projects.AsNoTracking().OrderBy(p => p.Title).ToListAsync();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (model.Source == RevenueSource.ProjectWork && model.ProjectId is null)
            return;

        var state = await AuthTask;
        var userName = state.User.Identity?.Name;

        model.AddCreatedStamps(userName);
        model.IsActive = true;

        Db.Revenues.Add(model);
        var rowsAffected = await Db.SaveChangesAsync();

        if (rowsAffected > 0)
        {
            SnackBar.Add("New revenue item added successfully", Severity.Success);
            model = new() { Amount = 0.0f, Date = DateTime.Now };
        }
        else
        {
            SnackBar.Add("New revenue item save failed", Severity.Error);
        }
    }
}
