<div class="tree-node">
    <div class="tree-node-row" @onclick="ToggleExpand" @onclick:preventDefault>
        <div class="tree-node-toggle">
            @if (HasChildren)
            {
                <MudIcon Icon="@(_expanded ? Icons.Material.Filled.KeyboardArrowDown : Icons.Material.Filled.KeyboardArrowRight)"
                         Size="Size.Small" Class="tree-toggle-icon" />
            }
            else
            {
                <span class="tree-toggle-spacer"></span>
            }
        </div>

        <div class="tree-node-content">
            <div class="tree-node-avatar">
                <MudAvatar Style="height:36px; width:36px; font-size:0.9rem;" Elevation="2">
                    @if (!string.IsNullOrEmpty(Employee.ProfilePath))
                    {
                        <MudImage Src="@Employee.ProfilePath" Alt="@Employee.Name" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                    }
                </MudAvatar>
            </div>

            <div class="tree-node-info">
                <MudLink Href="@("/employees/edit/" + Employee.Id)" Class="tree-node-name">
                    @Employee.Name
                </MudLink>
                @if (!string.IsNullOrEmpty(Employee.Designation))
                {
                    <MudText Typo="Typo.caption" Class="tree-node-designation">@Employee.Designation</MudText>
                }
            </div>

            @if (!string.IsNullOrEmpty(Employee.Department))
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Class="tree-node-dept">@Employee.Department</MudChip>
            }

            @if (HasChildren)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Class="tree-node-reports">
                    <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Size="Size.Small" Class="mr-1" />@Employee.DirectReports!.Count
                </MudChip>
            }

            <div class="tree-node-actions">
                @if (HasChildren)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" Size="Size.Small"
                                   Href="@("/employees/org/" + Employee.Id)" title="View organization hierarchy" />
                }
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small"
                               Href="@("/employees/edit/" + Employee.Id)" title="Edit employee" />
            </div>
        </div>
    </div>

    @if (_expanded && HasChildren)
    {
        <div class="tree-children">
            @{ var children = Employee.DirectReports!.OrderBy(r => r.Name).ToList(); }
            @foreach (var child in children)
            {
                <EmployeeTreeNode Employee="@child" />
            }
        </div>
    }
</div>

<style>
    .tree-node {
        display: flex;
        flex-direction: column;
    }
    .tree-node-row {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 5px 8px;
        border-radius: 8px;
        cursor: pointer;
        transition: background-color 0.15s ease;
    }
    .tree-node-row:hover {
        background-color: var(--mud-palette-surface);
    }
    .tree-node-toggle {
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .tree-toggle-icon {
        color: var(--mud-palette-text-secondary);
        transition: transform 0.2s ease;
    }
    .tree-toggle-spacer {
        width: 16px;
    }
    .tree-node-content {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
        flex: 1;
    }
    .tree-node-avatar {
        flex-shrink: 0;
    }
    .tree-node-info {
        display: flex;
        flex-direction: column;
        min-width: 0;
        flex: 1;
    }
    .tree-node-name {
        font-weight: 600;
        font-size: 0.9rem;
        line-height: 1.3;
        color: var(--mud-palette-text-primary);
        text-decoration: none !important;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .tree-node-name:hover {
        color: var(--mud-palette-primary);
        text-decoration: underline !important;
    }
    .tree-node-designation {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
        line-height: 1.3;
    }
    .tree-node-dept {
        flex-shrink: 0;
    }
    .tree-node-reports {
        flex-shrink: 0;
    }
    .tree-node-actions {
        display: flex;
        gap: 2px;
        flex-shrink: 0;
        opacity: 0;
        transition: opacity 0.15s ease;
    }
    .tree-node-row:hover .tree-node-actions {
        opacity: 1;
    }
    .tree-children {
        display: flex;
        flex-direction: column;
        border-left: 2px solid var(--mud-palette-lines-default);
        margin-left: 11px;
        opacity: 0.6;
    }
</style>

@code {
    [Parameter] public Employee Employee { get; set; } = default!;

    private bool _expanded = true;

    private bool HasChildren => Employee.DirectReports is not null && Employee.DirectReports.Count > 0;

    private void ToggleExpand()
    {
        if (HasChildren)
            _expanded = !_expanded;
    }
}
