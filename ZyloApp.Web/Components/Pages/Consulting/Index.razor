@page "/consulting/plans"

@attribute [Authorize(Roles = Role.Admins)]
@inject ApplicationDbContext Db
@inject ISnackbar SnackBar
@inject NavigationManager Navigation

<PageTitle>Customized Training Plans</PageTitle>

<MudDataGrid Items="@trainings"
             Dense="true"
             Hover="true"
             Outlined
             Class="mt-2"
             Loading="@loadingData">
    <ToolBarContent>
        <MudButton Variant="Variant.Outlined" Class="rounded" StartIcon="@Icons.Material.Outlined.Add" Href="/consulting/plans/add" Color="Color.Tertiary">New Plan</MudButton>
        <MudSpacer />
        <MudChip Text="Professional Consulting Plans" Label="true" Size="Size.Large" />
    </ToolBarContent>
    <Columns>
        <HierarchyColumn T="Training" ButtonDisabledFunc="@(x => (x.CourseQuote?.Modules?.Count ?? 0) == 0)" />
        <PropertyColumn Property="x => x.Title" />
        <PropertyColumn Property="x => x.Format" />
        <PropertyColumn Property="x => x.CourseQuote!.Code" Title="Course" />
        <PropertyColumn Property="x => x.Organization!.Name" Title="Beneficiary" />
        <PropertyColumn Property="x => x.DiscountPercentage" Title="Discount" />
        <PropertyColumn Property="x => x.Duration" />
        <TemplateColumn Title="Consultant">
            <CellTemplate>
                <MudTooltip Text="@context.Item.Instructor?.Name" Arrow="true" Placement="Placement.Bottom">
                    <MudAvatar>
                        <MudImage Src="@context.Item.Instructor?.ProfilePath" />
                    </MudAvatar>
                </MudTooltip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn>
            <CellTemplate>
                <MudContainer Class="d-flex align-center gap-0" Fixed="true" Gutters="false">
                    <MudSelect T="TrainingStatus"
                               Margin="Margin.Dense"
                               Value="@context.Item.Status"
                               Variant="Variant.Outlined"
                               ValueChanged="(s) => TrainingStatusChanged(context.Item, s)">
                        @foreach (var status in Enum.GetValues<TrainingStatus>())
                        {
                            <MudSelectItem Value="@status" />
                        }
                    </MudSelect>
                    <MudToolBar Dense>
                        <MudIconButton title="Share plan" Icon="@Icons.Material.Filled.Share" Target="_blank" Color="Color.Info" Href="@("/consulting/plans/" + context.Item.Hash)" />
                        <MudIconButton title="Clone plan" Icon="@Icons.Material.Filled.ContentCopy" Color="Color.Tertiary" OnClick="() => CloneNewPlan(context.Item)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Href="@("/consulting/plans/edit/" + context.Item.Id)" />
                        <MudIconButton Icon="@Icons.Material.Sharp.Delete" Color="Color.Error" OnClick="() => ConfirmDelete(context.Item)" />
                    </MudToolBar>
                    <MudMessageBox @ref="mbox" Title="Warning" CancelText="Cancel">
                        <MessageContent>
                            Are you sure to delete this training plan? It can't be undone.
                        </MessageContent>
                        <YesButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Error" Class="ml-2 mb-2 mr-3" StartIcon="@Icons.Material.Filled.DeleteForever">Delete</MudButton>
                        </YesButton>
                    </MudMessageBox>
                </MudContainer>
            </CellTemplate>
        </TemplateColumn>
    </Columns>

    <ChildRowContent>
        <MudGrid Spacing="1" Class="p-1" Style="background:#EEEEEE">
            @foreach (var module in context.Item.CourseQuote?.Modules ?? [])
            {
                <MudItem xs="12" md="6">
                    <MudExpansionPanels>
                        <Module Widget="@module" />
                    </MudExpansionPanels>
                </MudItem>
            }
        </MudGrid>
    </ChildRowContent>
    <PagerContent>
        <MudDataGridPager PageSizeOptions="[50, 100, 200, 500]" />
    </PagerContent>
</MudDataGrid>

@code {

    [CascadingParameter]
    private Task<AuthenticationState> AuthTask { get; set; } = null!;

    private List<Training> trainings = [];

    private bool loadingData = false;
    private string searchString = string.Empty;
    private MudMessageBox mbox { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        loadingData = true;

        trainings = await Db.Training
            .Include(x => x.Organization)
            .Include(x => x.Instructor)
            .Include(x => x.CourseQuote)
            .ThenInclude(y => y.Modules)
            .OrderByDescending(x => x.Created)
            .ToListAsync();

        loadingData = false;
    }

    private void TrainingStatusChanged(Training training, TrainingStatus status)
    {
        training.Status = status;
        var rowsAffected = Db.Training
                .Where(s => s.Id == training.Id)
                .ExecuteUpdate(x => x
                    .SetProperty(y => y.Status, status)
                );

        _ = (rowsAffected > 0)
            ? SnackBar.Add($"Training status updated to '{status}' successfully", Severity.Success)
            : SnackBar.Add("Training status update failed", Severity.Error);
    }

    private async Task ConfirmDelete(Training training)
    {
        bool? result = await mbox.ShowAsync();
        if (result == null)
            return;

        Db.Training.Remove(training);
        var rowsAffected = await Db.SaveChangesAsync();

        if (rowsAffected > 0)
        {
            SnackBar.Add("Training plan deleted successfully", Severity.Success);
            trainings.Remove(training);
        }
        else
        {
            SnackBar.Add("Training plan deletion failed", Severity.Error);
        }
    }

    private async Task CloneNewPlan(Training training)
    {
        var newPlan = new Training
        {
            Title = training.Title + " - Copy",
            Format = training.Format,
            DiscountPercentage = training.DiscountPercentage,
            Duration = training.Duration,
            CourseQuoteId = training.CourseQuoteId,
            InstructorId = training.InstructorId,
            OrganizationId = training.OrganizationId,
            Status = TrainingStatus.Drafted,
            Details = training.Details,
            Tags = training.Tags?.ToList() ?? [],
            Projects = training.Projects?.ToList() ?? [],
            Assignments = training.Assignments?.ToList() ?? []
        };

        var state = await AuthTask;
        var userName = state.User.Identity?.Name;
        newPlan.AddCreatedStamps(userName);
        newPlan.Hash = Guid.CreateVersion7().ToString();

        Db.Training.Add(newPlan);
        var rowsAffected = Db.SaveChanges();
        
        if (rowsAffected > 0)
        {
            SnackBar.Add("Training plan cloned successfully", Severity.Success);
            Navigation.NavigateTo("/consulting/plans/edit/" + newPlan.Id);
        }
        else
        {
            SnackBar.Add("Training plan cloning failed", Severity.Error);
        }
    }
}
