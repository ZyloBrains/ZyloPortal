@page "/"

@inject ApplicationDbContext db

<PageTitle>Home - ZyloBrains</PageTitle>

@if (homeAdminNavigations is null || homeConsultantNavigations.Count == 0)
{
    <Loading />
}
else
{
    <AuthorizeView Roles="@Role.Admins">
        <MudGrid Class="pb-8 mt-0 px-4">
            @foreach (var item in homeAdminNavigations)
            {
                <MudItem xs="12" sm="6" md="4" lg="3"">
                    <MudCard Class="nav-card admin" Elevation="10">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@item.Text</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Row="true">
                                <MudIcon Size="Size.Large" Icon="@item.Icon" />
                                <MudText Typo="Typo.body2">The quick, brown fox jumps over a lazy dog.</MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Text" Color="Color.Info" Href="@item.Link">Navigate to @item.Text</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </AuthorizeView>

    <AuthorizeView Roles="@Role.Instructor">
        <MudGrid Class="pb-8 mt-0 px-4">
            @foreach (var item in homeConsultantNavigations)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Class="nav-card consultant" Elevation="10">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@item.Text</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Row="true">
                                <MudIcon Size="Size.Large" Icon="@item.Icon" />
                                <MudText Typo="Typo.body2">The quick, brown fox jumps over a lazy dog.</MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Text" Color="Color.Info" Href="@item.Link">Navigate to @item.Text</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </AuthorizeView>

    <AuthorizeView Roles="@Role.TraineesOrAttendeesOrEmployees">
        <MudGrid Class="pb-8 mt-0 px-4">
            @foreach (var item in homeAdminNavigations)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Class="nav-card" Elevation="10">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@item.Text</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Row="true">
                                <MudIcon Size="Size.Large" Icon="@item.Icon" />
                                <MudText Typo="Typo.body2">The quick, brown fox jumps over a lazy dog.</MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Text" Color="Color.Info" Href="@item.Link">Navigate to @item.Text</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </AuthorizeView>
}

<style>
    .nav-card {
        transition: transform 0.3s ease-in-out;
    }

    .nav-card.admin {
        box-shadow: 0px 5px 15px rgba(244, 67, 54, 0.5) !important;
    }

    .nav-card.consultant {
        box-shadow: 0px 5px 15px rgba(25, 118, 210, 0.5) !important;
    }

    .nav-card:not(.admin):not(.consultant) {
        box-shadow: 0px 5px 15px rgba(156, 39, 176, 0.5) !important;
    }

    .nav-card:hover {
        transform: translateY(-8px);
    }
</style>

@code {

    private List<(string Text, string Link, string Icon)> homeAdminNavigations = [
        ("Dashboard", "/dashboard/admin", Icons.Material.Sharp.Dashboard),
        ("New Joinees", "/applicants", Icons.Material.Sharp.PeopleOutline),
        ("Courses", "/trainingplans", Icons.Material.Sharp.MenuBook),
        ("Reviews", "/review/forms", Icons.Material.Sharp.MenuBook),        
        ("Consultants", "/instructors", Icons.Material.Sharp.PersonOutline),
        ("Timesheets", "/timesheets", Icons.Material.Sharp.PeopleOutline)
    ];
    private List<(string Text, string Link, string Icon)> homeConsultantNavigations = [
        ("Dashboard", "/dashboard/admin", Icons.Material.Sharp.Dashboard),
        ("New Joinees", "/applicants", Icons.Material.Sharp.PeopleOutline),
        ("Courses", "/trainingplans", Icons.Material.Sharp.MenuBook),
        ("Consultants", "/instructors", Icons.Material.Sharp.PersonOutline),
        ("Timesheets", "/timesheets", Icons.Material.Sharp.PeopleOutline)
    ];
    private List<(string Text, string Link, string Icon)> homeUserNavigations = [];
}
